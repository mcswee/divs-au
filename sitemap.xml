---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% unless page.sitemap == false or page.url contains "404" or page.url contains "assets" %}
    <url>
      <loc>{{ site.url }}{{ page.url | remove: 'index.html' }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <priority>
        {% if page.url == "/" %}1.0
        {% comment %} Capture reports index and methodology/naming via category {% endcomment %}
        {% elsif page.categories contains 'reports' %}0.9
        {% comment %} Capture legal pages by their source folder {% endcomment %}
        {% elsif page.path contains 'legal/' %}0.2
        {% else %}0.6
        {% endif %}
      </priority>
    </url>
    {% endunless %}
  {% endfor %}

  {% for collection in site.collections %}
    {% for doc in collection.docs %}
    <url>
      <loc>{{ site.url }}{{ doc.url }}</loc>
      <lastmod>{{ doc.date | date_to_xmlschema | default: site.time | date_to_xmlschema }}</lastmod>
      <priority>
        {% case collection.label %}
        {% when 'reports' %}0.9
        {% when 'flags' %}0.5
        {% when 'us_flags' %}0.47
        {% else %}0.5
        {% endcase %}
      </priority>
    </url>
    {% endfor %}
  {% endfor %}
</urlset>
